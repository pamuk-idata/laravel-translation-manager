{
    "name": "pamuk-idata/laravel-translation-manager",
    "description": "Enhanced Laravel Translation Manager (Laravel 10 compatible fork)",
    "keywords": [
        "laravel",
        "translations",
        "translator"
    ],
    "homepage": "https://github.com/pamuk-idata/laravel-translation-manager",
    "license": "MIT",
    "authors": [
        {
            "name": "Vladimir Schneider",
            "email": "vladimir.schneider@gmail.com",
            "role": "Original Developer"
        },
        {
            "name": "Faruk Pamuk",
            "role": "Maintainer (Laravel 10 fork)"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0",
        "illuminate/translation": "^10.0",
        "laravelcollective/html": "^6.4",
        "doctrine/dbal": "^3.0",
        "symfony/finder": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "classmap": [
            "src/Classes"
        ],
        "files": [
            "src/Support/helpers.php"
        ],
        "psr-4": {
            "Vsch\\TranslationManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vsch\\TranslationManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vsch\\TranslationManager\\ManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
